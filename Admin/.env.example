# ============================================================
# Lemini Admin — Environment Variables
# Copy file này thành .env.local và điền giá trị thật
# ============================================================

# --- Supabase (Phase 1) ---
# Lấy từ: supabase.com > Project Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Admin Auth ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# --- CORS (URL của User app khi deploy) ---
CORS_ORIGIN=http://localhost:3000

# --- Cloudinary (Phase 3) ---
# Lấy từ: cloudinary.com > Dashboard > Product Environment Credentials
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Email Resend (Phase 4) ---
# RESEND_API_KEY=
